{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Fluso",
  "description": "Fluso is an AI executive assistant that works inside your tools — email, calendar, Slack, GitHub, and 100+ more. Read the docs to get set up, connect your apps, and put Fluso to work.",
  "colors": {
    "primary": "#5B21B6",
    "light": "#7C3AED",
    "dark": "#3B0764"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "appearance": {
    "default": "light"
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "introduction",
          "quickstart",
          "connect-apps",
          "first-week"
        ]
      },
      {
        "group": "Features",
        "pages": [
          "features/chat",
          "features/email",
          "features/calendar",
          "features/tasks",
          "features/memory",
          "features/content",
          "features/research",
          "features/code"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "integrations/overview",
          "integrations/gmail",
          "integrations/google-calendar",
          "integrations/slack",
          "integrations/github",
          "integrations/all-apps"
        ]
      },
      {
        "group": "Use cases",
        "pages": [
          "use-cases/overview",
          "use-cases/morning-brief",
          "use-cases/email-triage",
          "use-cases/meetings",
          "use-cases/research-to-deck",
          "use-cases/content-launch",
          "use-cases/dev-bug-fix",
          "use-cases/knowledge-recall"
        ]
      },
      {
        "group": "Resources",
        "pages": [
          "resources/pricing",
          "resources/security",
          "resources/faq"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Log in",
        "href": "https://app.fluso.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try Fluso",
      "href": "https://app.fluso.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/premai_io",
      "github": "https://github.com/premAI-io",
      "linkedin": "https://linkedin.com/company/premai"
    }
  }
}
