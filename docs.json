{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Fluso",
  "description": "Fluso is an AI executive assistant that works inside your tools — email, calendar, Slack, GitHub, and 100+ more. Read the docs to get set up, connect your apps, and put Fluso to work.",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "App",
          "icon": "external-link",
          "href": "https://app.fluso.ai"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "mailto:support@premai.io"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "introduction",
          "quickstart",
          "connect-apps",
          "first-week"
        ]
      },
      {
        "group": "Features",
        "icon": "sparkles",
        "expanded": true,
        "pages": [
          "features/chat",
          "features/email",
          "features/calendar",
          "features/tasks",
          "features/memory",
          "features/content",
          "features/research",
          "features/code"
        ]
      },
      {
        "group": "Integrations",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "integrations/overview",
          "integrations/gmail",
          "integrations/google-calendar",
          "integrations/slack",
          "integrations/github",
          "integrations/all-apps"
        ]
      },
      {
        "group": "Use cases",
        "icon": "lightbulb",
        "expanded": true,
        "pages": [
          "use-cases/overview",
          "use-cases/morning-brief",
          "use-cases/email-triage",
          "use-cases/meetings",
          "use-cases/research-to-deck",
          "use-cases/content-launch",
          "use-cases/dev-bug-fix",
          "use-cases/knowledge-recall"
        ]
      },
      {
        "group": "Resources",
        "icon": "book-open",
        "expanded": true,
        "pages": [
          "resources/pricing",
          "resources/security",
          "resources/faq"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Log in",
        "href": "https://app.fluso.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try Fluso free",
      "href": "https://app.fluso.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/premai_io",
      "github": "https://github.com/premAI-io",
      "linkedin": "https://linkedin.com/company/premai"
    }
  }
}
